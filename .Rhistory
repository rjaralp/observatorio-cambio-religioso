library(dplyr)
library(janitor)
library(stringr)
# Importar base
bic <- read_dta("datos/raw/bicentenario_limpio.dta")
# Revisar estructura inicial
glimpse(bic)
names(bic)
# Recodificación de religión
bic <- bic %>%
mutate(
religion_cat = case_when(
religion_encuestado == 1 ~ "Católica",
religion_encuestado %in% c(2, 3) ~ "Evangélica",
religion_encuestado == 4 ~ "Otras religiones",
religion_encuestado %in% c(5, 6) ~ "Sin religión",
TRUE ~ NA_character_
)
)
saveRDS(bic, "datos/processed/bicentenario_clean.rds")
library(dplyr)
library(ggplot2)
library(scales)
setwd("C:/Users/Dell/Desktop/observatorio-cambio-religioso")
bic <- readRDS("datos/processed/bicentenario_clean.rds")
list.files("datos/processed")
getwd()
bic <- readRDS("C:/Users/Dell/Desktop/observatorio-cambio-religioso/datos/processed/bicentenario_clean.rds")
religion_ts_bic <- bic %>%
filter(!is.na(religion_cat), !is.na(ano)) %>%
count(ano, religion_cat) %>%
group_by(ano) %>%
mutate(prop = n / sum(n)) %>%
ungroup()
religion_ts_bic
ggplot(religion_ts_bic, aes(x = ano, y = prop, color = religion_cat)) +
geom_line(linewidth = 1.2) +
scale_y_continuous(labels = percent) +
labs(
title = "Cambio en la Identificación Religiosa en Chile (Encuesta Bicentenario)",
x = "Año",
y = "Porcentaje",
color = "Religión"
) +
theme_minimal()
