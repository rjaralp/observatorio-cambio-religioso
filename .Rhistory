count(ola, religion_cat) %>%
group_by(ola) %>%
mutate(prop = n / sum(n)) %>%
ungroup()
elsoc_ts
ggplot(elsoc_ts, aes(x = ola, y = prop, color = religion_cat)) +
geom_line(linewidth = 1.2) +
scale_y_continuous(labels = scales::percent) +
